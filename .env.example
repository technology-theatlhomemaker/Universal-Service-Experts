# Apps Script Web App URL — the /exec URL from Deploy → New deployment.
# Used by PHP (api/lead.php, api/retry.php) when forwarding queued leads.
APPS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# Hostinger MySQL — copy these from hPanel → Databases → MySQL Databases.
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# Long random string that gates /api/retry.php and /api/migrate.php.
# Generate with: php -r 'echo bin2hex(random_bytes(24));'
ADMIN_TOKEN=
